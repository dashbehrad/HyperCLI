```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Database
database.db

# Environment
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Coverage
.coverage
coverage/
htmlcov/

# Dependencies
.venv/
venv/
pip-log.txt
pip-selfcheck.json

# Build artifacts
build/
dist/
*.egg-info/

# OS generated files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/
```